# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3001

# SuperTokens Core (the auth server you run via Docker)
SUPERTOKENS_CONNECTION_URI=http://localhost:3567

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wellness_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Allowed frontend origins (comma-separated)
DOCTOR_PORTAL_URL=http://localhost:3002
ADMIN_PORTAL_URL=http://localhost:3003
PATIENT_APP_URL=http://localhost:8081

# Google Gemini API — used for AI food image analysis
# Get your free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
